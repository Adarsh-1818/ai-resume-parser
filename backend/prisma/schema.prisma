generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String @id @default(uuid())
  firstName    String
  lastName     String
  email        String @unique
  passwordHash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResumeScan {
  id              String   @id @default(uuid())
  userId          String
  atsScore        Int
  missingSkills   String
  summary         String
  createdAt       DateTime @default(now())
}